# ─── Database ───────────────────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=nexus_core
DB_USER=nexus
DB_PASSWORD=nexus_secret

# Auth service uses separate DB
AUTH_DB_NAME=nexus_auth

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Django ─────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,nginx

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── AI / LLM ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
# Or use local Ollama:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── Search ─────────────────────────────────────────────────────────────────
BRAVE_API_KEY=your-brave-search-api-key-here

# ─── Celery ─────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# ─── Selenium ───────────────────────────────────────────────────────────────
SELENIUM_HEADLESS=true
SELENIUM_IMPLICIT_WAIT=10
SELENIUM_PAGE_LOAD_TIMEOUT=30

# ─── Rate Limiting ──────────────────────────────────────────────────────────
SCRAPER_RATE_LIMIT_REQUESTS=10
SCRAPER_RATE_LIMIT_WINDOW_SECONDS=60

# ─── MySQL root (for init) ───────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_USER=nexus
MYSQL_PASSWORD=nexus_secret
